<% layout("../layouts/boilerplate") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-3">
            <h3>Listing Details: </h3>
        </div>
        <div class="card col-6 offset-3">
            <img class="card-img-top show-img" src="<%= listing.image %>" alt="listing_image">
            <div class="card-body">
                <b><p class="card-text"><%= list.title %></p> </b> <br>
                <%= list.description %> <br>
                &#8377; <%= list.price.toLocaleString("en-IN") %> <br>
                <%= list.location %> <br>
                <%= list.country %>
            </div>
        </div>
        <div class="col-6 offset-3 btns">
             <a href="/listings/<%= list._id %>/edit" class="btn btn-dark"> EDIT POST</a>
            <form action="/listings/<%= list._id %>?_method=DELETE" method="POST">
                <button class="btn add-btn" >DELETE POST</button>
            </form>
        </div>
    </div>

</body>
